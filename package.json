{
  "name": "tic-tac-toe",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@emotion/react": "^11.5.0",
    "@emotion/styled": "^11.3.0",
    "@mui/material": "^5.0.4",
    "animate.css": "^4.1.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-redux": "^7.2.5",
    "redux": "^4.1.1",
    "socket.io-client": "^4.8.3"
  },
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"vite\"",
    "dev:web": "vite",
    "server:dev": "node server/index.js",
    "start": "node server/index.js",
    "build": "npm install --prefix server && tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run && node --test server/game.test.js server/rooms.test.js",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/react": "^17.0.30",
    "@types/react-dom": "^17.0.9",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^3.0.5"
  }
}
